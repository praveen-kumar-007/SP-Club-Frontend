# Frontend Environment Variables
# Copy this file to .env.local and fill in your values for different environments

# API URL
VITE_API_URL=https://api.spkabaddi.me

# Optional: frontend base URL (used by backend-generated links when FRONTEND_URL points here)
# Keep this aligned with deployed domain
VITE_FRONTEND_URL=https://spkabaddi.me

# Google Maps Embed API key (required for embedded map iframe)
# Create key in Google Cloud and enable Maps Embed API
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE
